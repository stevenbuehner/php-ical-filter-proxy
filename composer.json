{
  "name": "app/php-ical-filter-proxy",
  "description": "Leichtgewichtiger iCal Proxy & Filter Service",
  "type": "project",
  "require": {
    "php": "^8.3",
    "sabre/vobject": "^4.5",
    "symfony/yaml": "^7.0",
    "symfony/http-foundation": "^7.0",
    "symfony/routing": "^7.0",
    "symfony/http-client": "^7.0",
    "symfony/cache": "^7.0",
    "symfony/console": "^7.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "require-dev": {
    "phpunit/phpunit": "^11.0"
  },
  "scripts": {
    "post-install-cmd": [
      "@composer dump-autoload"
    ],
    "post-update-cmd": [
      "@composer dump-autoload"
    ]
  },
  "config": {
    "platform": {
      "php": "8.3.0"
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "license": "MIT"
}
